{
  "base": {
    "canonicalViewport": {
      "width": 430,
      "height": 900,
      "source": "inferred from approved wireframe"
    },
    "contentBox": {
      "gutterX": 16,
      "width": 398
    },
    "sceneVariables": {
      "--platform-visual-w": "min(64vw, 260px)",
      "--platform-offset-x": "0px",
      "--platform-offset-y": "-11px",
      "--rover-w": "min(51vw, 198px)",
      "--rover-y": "-10px"
    },
    "zIndex": {
      "background": -1,
      "cardGlow": 0,
      "platform": 0,
      "rover": 1,
      "nativeUi": 3,
      "topbar": 5
    }
  },
  "viewportTiers": {
    "compactPhone": {
      "range": "320-374px",
      "contentMaxWidth": "100%",
      "allowedChanges": [
        "reduce vertical gaps",
        "stack action buttons",
        "shrink connection map icons",
        "crop Lyra lower body"
      ],
      "blockedChanges": [
        "reorder sections",
        "remove safety note",
        "turn phone UI into desktop layout"
      ]
    },
    "designLockedPhone": {
      "range": "375-479px",
      "contentMaxWidth": "430px",
      "heroHeightTarget": "90px",
      "visualCardTarget": "220px",
      "lowerDensity": "compact but readable",
      "qaViewport": "430x900"
    },
    "desktopStage": {
      "range": ">=768px",
      "contentMaxWidth": "452px",
      "outerStagePadding": "40px",
      "behavior": "center the phone stage and let background expand; do not create a separate desktop dashboard"
    }
  }
}
