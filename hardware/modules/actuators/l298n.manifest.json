{
  "manifestVersion": "0.1",
  "moduleId": "rf.actuator.motor_driver.l298n",
  "moduleType": "actuator",
  "displayName": "L298N Dual H-Bridge Motor Driver",
  "bus": "gpio",
  "capabilities": ["dual_motor_drive", "pwm_speed_control"],
  "requiresFirmware": ">=0.1.0",
  "compatibleRobotTypes": ["rover"],
  "safetyNotes": [
    "Use for prototype validation only; confirm current and heat before floor tests.",
    "Remove ENA/ENB jumpers when firmware controls PWM."
  ],
  "metadata": {
    "defaultPins": {
      "ena": 25,
      "in1": 26,
      "in2": 27,
      "enb": 33,
      "in3": 32,
      "in4": 14
    }
  }
}
