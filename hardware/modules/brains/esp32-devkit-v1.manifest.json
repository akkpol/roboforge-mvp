{
  "manifestVersion": "0.1",
  "moduleId": "rf.brain.esp32.devkit-v1",
  "moduleType": "brain",
  "displayName": "ESP32 DevKit V1",
  "bus": "wifi",
  "capabilities": ["local_wifi_ap", "http_control_api", "littlefs_cockpit"],
  "requiresFirmware": ">=0.1.0",
  "compatibleRobotTypes": ["rover"],
