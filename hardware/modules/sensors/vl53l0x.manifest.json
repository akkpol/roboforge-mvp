{
  "manifestVersion": "0.1",
  "moduleId": "rf.sensor.distance.vl53l0x",
  "moduleType": "sensor",
  "displayName": "VL53L0X Distance Sensor",
  "bus": "i2c",
  "capabilities": ["distance_mm", "mission_telemetry", "obstacle_awareness"],
  "requiresFirmware": ">=0.2.0",
