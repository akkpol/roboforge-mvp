{
  "manifestVersion": "0.1",
  "kitId": "rf.kit.rover-01.beta",
  "displayName": "RoboForge Rover-01 Beta Kit",
  "robotType": "rover",
  "protocolVersion": "v1",
  "requiredModuleIds": [
    "rf.brain.esp32.devkit-v1",
    "rf.actuator.motor_driver.l298n",
    "rf.actuator.motor.tt_dc_pair",
    "rf.power.pack.18650_2s"
  ],
  "optionalSlots": [
    {
      "slotId": "front-distance",
      "displayName": "Front distance sensor",
      "acceptedModuleTypes": ["sensor"],
      "acceptedBuses": ["i2c"],
      "recommendedModuleIds": ["rf.sensor.distance.vl53l0x"]
    }
  ],
  "profileDefaults": {
    "profileVersion": "0.1",
    "mechanism": {
      "drive": "differential_drive",
      "motorDriver": "L298N dual H-bridge"
    },
    "muscle": {
      "actuators": ["left_drive_motor", "right_drive_motor"]
    },
    "communication": {
      "mode": "local_wifi",
      "localUrl": "http://192.168.4.1"
    },
    "safety": {
      "requiresArm": true,
      "raisedWheelTestRequired": true,
      "readiness": "ready_for_bench"
    }
  },
  "firmware": {
    "targetBoard": "esp32dev",
    "framework": "arduino",
    "configTemplate": "hardware/templates/esp32_rover_config.h.mustache",
    "currentVersion": "0.1.0"
  },
  "safetyGates": [
    "hardware_profile_complete",
    "power_switch_verified",
    "fuse_or_protected_pack_verified",
    "bench_protocol_check",
    "raised_wheel_test_passed"
  ]
}
